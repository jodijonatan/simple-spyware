datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Command {
  id        Int      @id @default(autoincrement())
  command   String
  result    String?
  status    String   @default("pending")
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
}

model Agent {
  id         String    @id @default(uuid())
  hostname   String    @unique
  ip_address String
  last_seen  DateTime  @updatedAt
  commands   Command[]
  logs       Log[]
}

model Log {
  id            Int      @id @default(autoincrement())
  type          String   
  content       String
  createdAt     DateTime @default(now())
  agent         Agent    @relation(fields: [agentHostname], references: [hostname])
  agentHostname String
}